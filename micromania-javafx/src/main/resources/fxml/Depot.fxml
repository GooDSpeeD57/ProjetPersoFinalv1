<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.monprojet.boutiquejeux.controller.DepotController"
      spacing="14" styleClass="view-container">
    <padding><Insets top="18" bottom="18" left="18" right="18"/></padding>

    <Label text="🏭 Gestion Dépôt &amp; Logistique" styleClass="page-title"/>
    <Separator/>

    <TabPane VBox.vgrow="ALWAYS" styleClass="tab-pane-dark" tabClosingPolicy="UNAVAILABLE">

        <!-- ══════════════════════════════════════════════════════
             ONGLET 1 — STOCK DÉPÔT
        ══════════════════════════════════════════════════════ -->
        <Tab text="📦  Stock Dépôt">
            <HBox spacing="14" VBox.vgrow="ALWAYS">

                <!-- Colonne gauche : navigation produits/variants -->
                <VBox spacing="10" prefWidth="360" minWidth="320">

                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <ComboBox fx:id="depotEntrepotFilterCb" promptText="Tous les dépôts"
                                  maxWidth="160" styleClass="form-control-select"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <ProgressIndicator fx:id="spinnerDepot" maxWidth="24" maxHeight="24" visible="false"/>
                    </HBox>

                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <TextField fx:id="depotRechercheField" promptText="Rechercher un produit…"
                                   styleClass="text-field-dark" HBox.hgrow="ALWAYS"
                                   onAction="#handleDepotRecherche"/>
                        <Button text="🔍" onAction="#handleDepotRecherche" styleClass="btn-secondary"/>
                        <Button text="🔄" onAction="#handleDepotRefresh"   styleClass="btn-secondary"/>
                    </HBox>

                    <Label text="Produits" styleClass="section-title"/>
                    <TableView fx:id="depotTableProduits" prefHeight="200" styleClass="table-dark">
                        <columns>
                            <TableColumn fx:id="depotColPNom" text="Produit"    prefWidth="240" minWidth="240"/>
                            <TableColumn fx:id="depotColPCat" text="Catégorie"  prefWidth="90" minWidth="90"/>
                        </columns>
                    </TableView>

                    <Label text="Variants" styleClass="section-title"/>
                    <TableView fx:id="depotTableVariants" VBox.vgrow="ALWAYS" styleClass="table-dark">
                        <columns>
                            <TableColumn fx:id="depotColVSku"    text="SKU"       prefWidth="105" minWidth="105"/>
                            <TableColumn fx:id="depotColVPlatf"  text="Support"   prefWidth="72" minWidth="72"/>
                            <TableColumn fx:id="depotColVStatut" text="État"      prefWidth="66" minWidth="66"/>
                        </columns>
                    </TableView>
                </VBox>

                <!-- Colonne droite : niveaux de stock + ajustement -->
                <VBox HBox.hgrow="ALWAYS" spacing="10">

                    <Label fx:id="depotLabelVariant" text="← Sélectionnez un variant"
                           styleClass="section-title"/>

                    <TableView fx:id="depotTableStock" prefHeight="220" styleClass="table-dark">
                        <columns>
                            <TableColumn fx:id="depotColLieu"    text="Dépôt"      prefWidth="160" minWidth="160"/>
                            <TableColumn fx:id="depotColNeuf"    text="Neuf"        prefWidth="70" minWidth="70"/>
                            <TableColumn fx:id="depotColReservee" text="Réservé"   prefWidth="70" minWidth="70"/>
                            <TableColumn fx:id="depotColDispo"   text="Disponible"  prefWidth="80" minWidth="80"/>
                        </columns>
                    </TableView>

                    <VBox spacing="10" styleClass="card" VBox.vgrow="ALWAYS">
                        <padding><Insets top="12" bottom="12" left="12" right="12"/></padding>

                        <Label text="⚙️  Ajustement de stock dépôt" styleClass="section-title"/>

                        <GridPane hgap="12" vgap="8">
                            <columnConstraints>
                                <ColumnConstraints prefWidth="120" minWidth="120"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                                <ColumnConstraints prefWidth="110" minWidth="110"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                            </columnConstraints>

                            <Label text="Dépôt *" styleClass="field-label"
                                   GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <ComboBox fx:id="depotAjustEntrepotCb" maxWidth="Infinity"
                                      promptText="— Choisir —"
                                      GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                            <Label text="Quantité *" styleClass="field-label"
                                   GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                            <TextField fx:id="depotAjustQteField" promptText="ex : 10"
                                       styleClass="text-field-dark"
                                       GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                            <Label text="Commentaire" styleClass="field-label"
                                   GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <TextField fx:id="depotAjustCommentField"
                                       promptText="Motif de l'ajustement…"
                                       styleClass="text-field-dark"
                                       GridPane.rowIndex="1" GridPane.columnIndex="1"
                                       GridPane.columnSpan="3"/>
                        </GridPane>

                        <HBox spacing="10">
                            <Button text="➕  Entrée en stock" onAction="#handleDepotEntree"
                                    styleClass="btn-success" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                            <Button text="➖  Sortie du stock" onAction="#handleDepotSortie"
                                    styleClass="btn-danger" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </VBox>
                </VBox>
            </HBox>
        </Tab>

        <!-- ══════════════════════════════════════════════════════
             ONGLET 2 — TRAITEMENT DES COMMANDES
        ══════════════════════════════════════════════════════ -->
        <Tab text="📋  Commandes à traiter">
            <HBox spacing="14" VBox.vgrow="ALWAYS">

                <!-- Liste des commandes -->
                <VBox spacing="10" prefWidth="500" minWidth="460">

                    <!-- Barre de filtre -->
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="Statut :" styleClass="field-label"/>
                        <ComboBox fx:id="cmdStatutCb" maxWidth="160" promptText="Tous"
                                  styleClass="form-control-select"/>
                        <Button text="🔍" onAction="#handleCmdFilter" styleClass="btn-secondary"/>
                        <Button text="🔄" onAction="#handleCmdRefresh" styleClass="btn-secondary"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <ProgressIndicator fx:id="spinnerCmd" maxWidth="24" maxHeight="24" visible="false"/>
                    </HBox>

                    <TableView fx:id="tableCommandes" VBox.vgrow="ALWAYS" styleClass="table-dark">
                        <columns>
                            <TableColumn fx:id="colCmdRef"       text="Référence"   prefWidth="135" minWidth="135"/>
                            <TableColumn fx:id="colCmdStatut"    text="Statut"      prefWidth="90" minWidth="90"/>
                            <TableColumn fx:id="colCmdLivraison" text="Livraison"   prefWidth="80" minWidth="80"/>
                            <TableColumn fx:id="colCmdMontant"   text="Montant"     prefWidth="75" minWidth="75"/>
                            <TableColumn fx:id="colCmdArticles"  text="Articles"    prefWidth="56" minWidth="56"/>
                            <TableColumn fx:id="colCmdDate"      text="Date"        prefWidth="130" minWidth="130"/>
                        </columns>
                    </TableView>
                </VBox>

                <!-- Détail et actions -->
                <VBox HBox.hgrow="ALWAYS" spacing="10">

                    <Label fx:id="labelCmdTitre" text="← Sélectionnez une commande"
                           styleClass="section-title"/>

                    <!-- Infos générales commande -->
                    <VBox fx:id="panelCmdDetail" spacing="8" styleClass="card">
                        <padding><Insets top="10" bottom="10" left="12" right="12"/></padding>

                        <GridPane hgap="12" vgap="6">
                            <columnConstraints>
                                <ColumnConstraints prefWidth="130" minWidth="130"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                            </columnConstraints>
                            <Label text="Référence :"    styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <Label fx:id="lblCmdRef"     styleClass="field-value" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                            <Label text="Statut :"       styleClass="field-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <Label fx:id="lblCmdStatut"  styleClass="field-value" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                            <Label text="Livraison :"    styleClass="field-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <Label fx:id="lblCmdLivraison" styleClass="field-value" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                            <Label text="Paiement :"     styleClass="field-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                            <Label fx:id="lblCmdPaiement" styleClass="field-value" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                            <Label text="Total :"        styleClass="field-label" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                            <Label fx:id="lblCmdTotal"   styleClass="field-value" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                            <Label text="Date commande :" styleClass="field-label" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                            <Label fx:id="lblCmdDate"    styleClass="field-value" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                            <Label text="Commentaire :"  styleClass="field-label" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                            <Label fx:id="lblCmdCommentaire" styleClass="field-value" wrapText="true"
                                   GridPane.rowIndex="6" GridPane.columnIndex="1"/>
                        </GridPane>
                    </VBox>

                    <!-- Lignes de commande -->
                    <Label text="Articles commandés" styleClass="section-title"/>
                    <TableView fx:id="tableCmdLignes" prefHeight="150" styleClass="table-dark">
                        <columns>
                            <TableColumn fx:id="colLigneNom"    text="Produit"     prefWidth="200" minWidth="200"/>
                            <TableColumn fx:id="colLigneSku"    text="SKU"         prefWidth="100" minWidth="100"/>
                            <TableColumn fx:id="colLigneQte"    text="Qté"         prefWidth="45" minWidth="45"/>
                            <TableColumn fx:id="colLignePrix"   text="Prix unit."  prefWidth="80" minWidth="80"/>
                            <TableColumn fx:id="colLigneMontant" text="Montant"    prefWidth="80" minWidth="80"/>
                        </columns>
                    </TableView>

                    <!-- Boutons d'action selon le statut -->
                    <VBox spacing="8" styleClass="card">
                        <padding><Insets top="10" bottom="10" left="12" right="12"/></padding>
                        <Label text="Actions" styleClass="section-title"/>
                        <FlowPane hgap="8" vgap="6">
                            <Button fx:id="btnPrendreEnCharge" text="▶ Prendre en charge"
                                    onAction="#handlePrendreEnCharge" styleClass="btn-primary"/>
                            <Button fx:id="btnMarquerExpediee" text="🚚 Marquer expédiée"
                                    onAction="#handleMarquerExpediee" styleClass="btn-success"/>
                            <Button fx:id="btnMarquerLivree"   text="✔ Marquer livrée"
                                    onAction="#handleMarquerLivree"   styleClass="btn-success"/>
                            <Button fx:id="btnMarquerRetirable" text="🏪 Prêt au retrait"
                                    onAction="#handleMarquerRetirable" styleClass="btn-secondary"/>
                            <Button fx:id="btnAnnulerCommande" text="✗ Annuler"
                                    onAction="#handleAnnulerCommande" styleClass="btn-danger"/>
                        </FlowPane>
                    </VBox>
                </VBox>
            </HBox>
        </Tab>

        <!-- ══════════════════════════════════════════════════════
             ONGLET 3 — EXPÉDITIONS COLIS
        ══════════════════════════════════════════════════════ -->
        <Tab text="🚚  Expéditions">
            <HBox spacing="14" VBox.vgrow="ALWAYS">

                <!-- Liste expéditions en attente -->
                <VBox spacing="10" prefWidth="480" minWidth="420">

                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="Commandes à expédier" styleClass="section-title" HBox.hgrow="ALWAYS"/>
                        <Button text="🔄" onAction="#handleExpedRefresh" styleClass="btn-secondary"/>
                        <ProgressIndicator fx:id="spinnerExped" maxWidth="24" maxHeight="24" visible="false"/>
                    </HBox>

                    <!-- Sous-onglets : Livraison domicile | Click &amp; Collect -->
                    <TabPane fx:id="expedSubTabs" styleClass="tab-pane-dark" tabClosingPolicy="UNAVAILABLE"
                             prefHeight="400">

                        <Tab text="🏠  Livraison domicile">
                            <VBox spacing="8">
                                <TableView fx:id="tableExpedDomicile" VBox.vgrow="ALWAYS" styleClass="table-dark">
                                    <columns>
                                        <TableColumn fx:id="colExpDRef"    text="Réf."       prefWidth="125" minWidth="125"/>
                                        <TableColumn fx:id="colExpDStatut" text="Statut"     prefWidth="90" minWidth="90"/>
                                        <TableColumn fx:id="colExpDTotal"  text="Montant"    prefWidth="75" minWidth="75"/>
                                        <TableColumn fx:id="colExpDDate"   text="Date"       prefWidth="115" minWidth="115"/>
                                    </columns>
                                </TableView>
                            </VBox>
                        </Tab>

                        <Tab text="🏪  Click &amp; Collect">
                            <VBox spacing="8">
                                <TableView fx:id="tableExpedCollect" VBox.vgrow="ALWAYS" styleClass="table-dark">
                                    <columns>
                                        <TableColumn fx:id="colExpCRef"    text="Réf."       prefWidth="125" minWidth="125"/>
                                        <TableColumn fx:id="colExpCStatut" text="Statut"     prefWidth="90" minWidth="90"/>
                                        <TableColumn fx:id="colExpCTotal"  text="Montant"    prefWidth="75" minWidth="75"/>
                                        <TableColumn fx:id="colExpCDate"   text="Date"       prefWidth="115" minWidth="115"/>
                                    </columns>
                                </TableView>
                            </VBox>
                        </Tab>
                    </TabPane>
                </VBox>

                <!-- Panneau expédition -->
                <VBox HBox.hgrow="ALWAYS" spacing="10">

                    <Label fx:id="labelExpedTitre" text="← Sélectionnez une commande"
                           styleClass="section-title"/>

                    <!-- Fiche expédition -->
                    <VBox spacing="8" styleClass="card">
                        <padding><Insets top="10" bottom="10" left="12" right="12"/></padding>
                        <Label text="📦 Fiche d'expédition" styleClass="section-title"/>

                        <GridPane hgap="12" vgap="6">
                            <columnConstraints>
                                <ColumnConstraints prefWidth="130" minWidth="130"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                            </columnConstraints>
                            <Label text="Référence :"       styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <Label fx:id="lblExpedRef"      styleClass="field-value" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                            <Label text="Mode livraison :"  styleClass="field-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <Label fx:id="lblExpedMode"     styleClass="field-value" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                            <Label text="Date commande :"   styleClass="field-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <Label fx:id="lblExpedDate"     styleClass="field-value" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                            <Label text="Nb articles :"     styleClass="field-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                            <Label fx:id="lblExpedNbArt"    styleClass="field-value" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                            <Label text="Montant total :"   styleClass="field-label" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                            <Label fx:id="lblExpedMontant"  styleClass="field-value" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                        </GridPane>
                    </VBox>

                    <!-- Articles à expédier -->
                    <TableView fx:id="tableExpedLignes" prefHeight="140" styleClass="table-dark">
                        <columns>
                            <TableColumn fx:id="colExpLigneNom"  text="Produit"  prefWidth="210" minWidth="210"/>
                            <TableColumn fx:id="colExpLigneSku"  text="SKU"      prefWidth="100" minWidth="100"/>
                            <TableColumn fx:id="colExpLigneQte"  text="Qté"      prefWidth="45" minWidth="45"/>
                        </columns>
                    </TableView>

                    <!-- Actions -->
                    <VBox spacing="8" styleClass="card">
                        <padding><Insets top="10" bottom="10" left="12" right="12"/></padding>
                        <HBox spacing="10">
                            <Button fx:id="btnExpedExpedier" text="🚚 Confirmer expédition"
                                    onAction="#handleExpedConfirmer"
                                    styleClass="btn-success" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                            <Button fx:id="btnExpedLivrer" text="✔ Marquer livrée / retirée"
                                    onAction="#handleExpedLivrer"
                                    styleClass="btn-primary" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </VBox>
                </VBox>
            </HBox>
        </Tab>

        <!-- ══════════════════════════════════════════════════════
             ONGLET 4 — TRANSFERTS DÉPÔT → MAGASIN
        ══════════════════════════════════════════════════════ -->
        <Tab text="🔄  Transferts dépôt → magasin">
            <HBox spacing="20" VBox.vgrow="ALWAYS">

                <!-- Formulaire de transfert -->
                <VBox spacing="14" prefWidth="420" minWidth="380">

                    <Label text="Nouveau transfert" styleClass="section-title"/>

                    <VBox spacing="12" styleClass="card">
                        <padding><Insets top="14" bottom="14" left="14" right="14"/></padding>

                        <GridPane hgap="12" vgap="10">
                            <columnConstraints>
                                <ColumnConstraints prefWidth="130" minWidth="130"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                            </columnConstraints>

                            <Label text="Dépôt source *" styleClass="field-label"
                                   GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <ComboBox fx:id="transfertEntrepotCb" maxWidth="Infinity"
                                      promptText="— Choisir —"
                                      GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                            <Label text="Magasin dest. *" styleClass="field-label"
                                   GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <ComboBox fx:id="transfertMagasinCb" maxWidth="Infinity"
                                      promptText="— Choisir —"
                                      GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                            <Label text="Produit / Variant *" styleClass="field-label"
                                   GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <HBox spacing="6"
                                  GridPane.rowIndex="2" GridPane.columnIndex="1">
                                <TextField fx:id="transfertRechercheVariant"
                                           promptText="Rechercher un produit…"
                                           styleClass="text-field-dark" HBox.hgrow="ALWAYS"
                                           onAction="#handleTransfertRechercheVariant"/>
                                <Button text="🔍" onAction="#handleTransfertRechercheVariant"
                                        styleClass="btn-secondary"/>
                            </HBox>

                            <Label text="Variant *" styleClass="field-label"
                                   GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                            <ComboBox fx:id="transfertVariantCb" maxWidth="Infinity"
                                      promptText="— Recherchez d'abord un produit —"
                                      GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                            <Label text="Quantité *" styleClass="field-label"
                                   GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                            <TextField fx:id="transfertQteField" promptText="ex : 5"
                                       styleClass="text-field-dark"
                                       GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                            <Label text="Commentaire" styleClass="field-label"
                                   GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                            <TextField fx:id="transfertCommentField"
                                       promptText="Motif optionnel…"
                                       styleClass="text-field-dark"
                                       GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                        </GridPane>

                        <!-- Stock dispo affiché en temps réel -->
                        <Label fx:id="labelStockDispoDepot"
                               text=""
                               style="-fx-font-size:11;-fx-text-fill:#aaa;"/>

                        <HBox spacing="10">
                            <Button text="🔄 Effectuer le transfert" onAction="#handleEffectuerTransfert"
                                    styleClass="btn-success" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                            <Button text="✖ Réinitialiser" onAction="#handleResetTransfert"
                                    styleClass="btn-secondary"/>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- Historique des transferts -->
                <VBox HBox.hgrow="ALWAYS" spacing="10">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="Historique des transferts récents" styleClass="section-title"
                               HBox.hgrow="ALWAYS"/>
                        <Button text="🔄" onAction="#handleTransfertHistRefresh" styleClass="btn-secondary"/>
                        <ProgressIndicator fx:id="spinnerTransfert" maxWidth="24" maxHeight="24" visible="false"/>
                    </HBox>

                    <TableView fx:id="tableTransferts" VBox.vgrow="ALWAYS" styleClass="table-dark">
                        <columns>
                            <TableColumn fx:id="colTrfProduit"    text="Produit / SKU"  prefWidth="200" minWidth="200"/>
                            <TableColumn fx:id="colTrfLieu"       text="Dépôt / Mag."   prefWidth="170" minWidth="170"/>
                            <TableColumn fx:id="colTrfQte"        text="Qté"            prefWidth="50" minWidth="50"/>
                            <TableColumn fx:id="colTrfCommentaire" text="Commentaire"   prefWidth="180" minWidth="180"/>
                            <TableColumn fx:id="colTrfDate"       text="Date"           prefWidth="130" minWidth="130"/>
                        </columns>
                    </TableView>
                </VBox>
            </HBox>
        </Tab>

    </TabPane>
</VBox>
