# Copier ce fichier en .env et remplir les valeurs avant de lancer en production.
# Ne jamais committer le fichier .env réel.

# === BASE DE DONNÉES ===
DB_URL=jdbc:mysql://localhost:3306/Micromania?useSSL=false&serverTimezone=Europe/Paris&allowPublicKeyRetrieval=true
DB_USER=changeme
DB_PASSWORD=changeme

# === JWT ===
# Générer avec : openssl rand -base64 48
JWT_SECRET=remplacer-par-une-chaine-aleatoire-de-minimum-32-caracteres
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_MS=604800000

# === IMAGES ===
APP_IMAGES_PATH=./media/images

# === REMEMBER ME ===
REMEMBER_ME_VALIDITY_DAYS=30
